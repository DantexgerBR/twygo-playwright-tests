# Normaliza fim de linha: o repo guarda LF; o checkout no Windows pode usar CRLF.
# Mata os avisos "LF will be replaced by CRLF".
* text=auto eol=lf

# Texto explícito (sempre LF no repo)
*.py   text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.ini  text eol=lf
*.cfg  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.env  text eol=lf

# Binários (nunca normalizar)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.zip  binary
*.webm binary
*.pptx binary
*.docx binary
